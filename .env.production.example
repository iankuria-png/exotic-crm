APP_NAME=ExoticCRM
APP_ENV=production
APP_DEBUG=false
APP_URL=https://crm.exotic-online.com
APP_KEY=  # php artisan key:generate

# One-time setup token — used by installation wizard, cleared after setup
SETUP_TOKEN=  # Generate: php -r "echo bin2hex(random_bytes(16));"

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=d9410_ExoticManagementDB
DB_USERNAME=
DB_PASSWORD=

QUEUE_CONNECTION=database
WALLET_ALLOW_REMOTE_SYNC_FROM_NON_PRODUCTION=false
EXOTIC_CRM_SYNC_SHARED_KEY=
EXOTIC_CRM_SYNC_SHARED_KEY_PLATFORM_IDS=
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=480

LOG_CHANNEL=daily
LOG_LEVEL=warning

SANCTUM_STATEFUL_DOMAINS=crm.exotic-online.com

# Billing feature rollout
BILLING_ENABLED=true
BILLING_FEATURE_WORKSPACE=true
BILLING_FEATURE_REGISTRY=true
BILLING_FEATURE_ROUTING=true
BILLING_FEATURE_PROVIDER_TRANSACTIONS=true
BILLING_FEATURE_DIAGNOSTICS_V2=true
BILLING_FEATURE_DUAL_WRITE=true
BILLING_FEATURE_SHADOW_READ=true
BILLING_FEATURE_BILLING_SYSTEM_LIVE_READ=true

# Optional billing capabilities
BILLING_FEATURE_WORDPRESS_VERSIONED_PAYLOADS=false
BILLING_FEATURE_WALLET_AUTO_RENEW=true

# Provider family availability
BILLING_PROVIDER_FAMILY_DARAJA=true
BILLING_PROVIDER_FAMILY_KOPOKOPO=true
BILLING_PROVIDER_FAMILY_PAWAPAY=true
BILLING_PROVIDER_FAMILY_ELEMITECH=false
BILLING_PROVIDER_FAMILY_DUSUPAY=false
BILLING_PROVIDER_FAMILY_NOWPAYMENTS=false
BILLING_PROVIDER_FAMILY_PESAPAL=true
BILLING_PROVIDER_FAMILY_PAYSTACK=true
BILLING_PROVIDER_FAMILY_PAYPAL=false

# Payment: Legacy Django/SwissSoft proxy (DEFAULT — M-Pesa STK)
DJANGO_API_BASE=https://polytech.co.ke/payment_service/api/payments
PAYMENT_LINK_PATH=/pay

# Payment: KopoKopo direct (alternative M-Pesa STK transport — switch in Settings)
# Copy these from the Ads API .env: /home/d9410/testing.exotic-ads.com/management/api/.env
KOPOKOPO_CLIENT_ID=
KOPOKOPO_CLIENT_SECRET=
KOPOKOPO_API_KEY=
KOPOKOPO_BASE_URL=https://api.kopokopo.com
KOPOKOPO_TILL_NUMBER=

# SMS
SMS_ENABLED=true
SMS_ACTIVE_PROVIDER=legacy_gateway
SMS_GATEWAY_URL=
SMS_ORG_CODE=
