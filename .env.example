APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
WALLET_ALLOW_REMOTE_SYNC_FROM_NON_PRODUCTION=false
EXOTIC_CRM_SYNC_SHARED_KEY=
EXOTIC_CRM_SYNC_SHARED_KEY_PLATFORM_IDS=
SESSION_DRIVER=file
SESSION_LIFETIME=120

PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_DB_CONNECTION=
PULSE_CACHE_DRIVER=
PULSE_SERVER_NAME=
PULSE_SERVER_DIRECTORIES=/
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_SLOW_JOBS_THRESHOLD=1000
PULSE_SLOW_QUERIES_THRESHOLD=1000
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=1000
PULSE_SLOW_OUTGOING_REQUESTS_WP_THRESHOLD=1500

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- CRM Payment Service (Django proxy for STK push) ---
DJANGO_API_BASE=https://polytech.co.ke/payment_service/api/payments
PAYMENT_LINK_PATH=/pay

# --- Billing feature flags (all off by default) ---
BILLING_ENABLED=false
BILLING_FEATURE_REGISTRY=false
BILLING_FEATURE_ROUTING=false
BILLING_FEATURE_PROVIDER_TRANSACTIONS=false
BILLING_FEATURE_DUAL_WRITE=false
BILLING_FEATURE_SHADOW_READ=false
BILLING_FEATURE_BILLING_SYSTEM_LIVE_READ=false
BILLING_FEATURE_DIAGNOSTICS_V2=false
BILLING_FEATURE_WORDPRESS_VERSIONED_PAYLOADS=false
BILLING_FEATURE_WALLET_AUTO_RENEW=false
BILLING_FEATURE_WORKSPACE=false
BILLING_PROVIDER_FAMILY_DARAJA=false
BILLING_PROVIDER_FAMILY_KOPOKOPO=false
BILLING_PROVIDER_FAMILY_PAWAPAY=false
BILLING_PROVIDER_FAMILY_ELEMITECH=false
BILLING_PROVIDER_FAMILY_DUSUPAY=false
BILLING_PROVIDER_FAMILY_NOWPAYMENTS=false
BILLING_PROVIDER_FAMILY_PESAPAL=false
BILLING_PROVIDER_FAMILY_PAYSTACK=false
BILLING_PROVIDER_FAMILY_PAYPAL=false

# --- KopoKopo (read-only in CRM; Django holds the active config) ---
KOPOKOPO_CLIENT_ID=
KOPOKOPO_CLIENT_SECRET=
KOPOKOPO_API_KEY=
KOPOKOPO_BASE_URL=
KOPOKOPO_TILL_NUMBER=

# --- SMS ---
SMS_ENABLED=false
SMS_ACTIVE_PROVIDER=legacy_gateway
SMS_FALLBACK_PROVIDER=none
SMS_GATEWAY_URL=
SMS_ORG_CODE=76
SMS_DEFAULT_PREFIX=254
AFRICASTALKING_ENDPOINT=https://api.africastalking.com/version1/messaging
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
